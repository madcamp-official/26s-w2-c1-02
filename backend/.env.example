# FastAPI 백엔드 환경변수 예시. 복사해서 .env로 사용하세요.
#   cp .env.example .env

# CORS 허용 오리진 (Flutter web dev 서버). 쉼표로 구분.
CORS_ORIGINS=http://localhost:*,http://127.0.0.1:*

# PostgreSQL 16 접속 정보 (backend/migrations/001_init.sql 적용된 DB)
DATABASE_URL=postgresql+psycopg://rehearsal:rehearsal123@localhost:5432/rehearsal_dev

# JWT 서명 시크릿. 각자 아래 명령으로 생성해서 자신의 .env에만 넣을 것 (커밋 금지).
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ACCESS_EXPIRES_SECONDS=900

# LLM 제공자: mock | gemini
LLM_PROVIDER=mock

# Gemini 연동 시 사용. AI Studio 키("AIza…")·Vertex express 키("AQ.…") 모두 지원.
# 실제 키는 커밋 금지 — .env(gitignore됨)에만 넣을 것.
GEMINI_API_KEY=
# 특정 버전을 고정하면 구글이 "no longer available to new users"로 게이팅할 때
# 404로 질문 생성이 전면 실패한다(gemini-2.5-flash가 그렇게 막혔다). 항상 사용 가능한
# 최신 flash 별칭을 기본으로 둔다.
GEMINI_MODEL=gemini-flash-latest
