# 릴리스 서명 키 설정 — 이 파일을 복사해 key.properties 로 만들고 값을 채운다.
#
#   cp android/key.properties.example android/key.properties
#
# key.properties 와 .jks(키스토어) 파일은 절대 커밋하지 말 것(.gitignore 등록됨).
# .jks 파일은 잃어버리면 앱 업데이트를 못 하게 되니 안전하게 백업할 것.
#
# 키스토어 생성(최초 1회, 본인 개발 머신에서):
#   keytool -genkey -v -keystore ~/rehearsal-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias rehearsal

storePassword=<키스토어 비밀번호>
keyPassword=<키 비밀번호(보통 storePassword 와 동일)>
keyAlias=rehearsal
storeFile=/절대/경로/rehearsal-release.jks
